#!/data/data/com.termux/files/usr/bin/bash

# 1. Gather folders from shared/ and DCIM/ — preserve DCIM subfolder names
#    so z_backup can resolve them correctly.
#    Excludes system noise and the Export folder itself.
LIST=$(
  {
    # Top-level folders in shared/ (excludes DCIM, Android, Export, hidden)
    find ~/storage/shared -maxdepth 1 -type d -not -path '*/.*' |
      sed 's|.*/||' |
      grep -vE "^(Export|Android|DCIM|shared)$"

    # Subfolders of DCIM/ (e.g. Camera, Screenshots) — bare names
    find ~/storage/shared/DCIM -maxdepth 1 -mindepth 1 -type d -not -path '*/.*' |
      sed 's|.*/||' |
      grep -vE "^(Export|Android)$"
  } | sort -u | tr '\n' ',' | sed 's/,$//'
)

if [ -z "$LIST" ]; then
    termux-dialog confirm -t "Error" -i "No folders found. Check permissions."
    exit 1
fi

# 2. Show the menu
SELECTED_JSON=$(termux-dialog radio -t "Select Folder to Zip" -v "$LIST")

# 3. Parse and Execute
FOLDER_NAME=$(echo "$SELECTED_JSON" | jq -r '.text // empty')

if [ -z "$FOLDER_NAME" ] || [ "$FOLDER_NAME" == "null" ]; then
    termux-toast "Cancelled"
    exit 0
fi

source ~/.bashrc
z_backup "$FOLDER_NAME"
