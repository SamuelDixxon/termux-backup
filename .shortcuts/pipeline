#!/data/data/com.termux/files/usr/bin/bash
# content-pipeline — run after a shoot
# Chains: org-camera-album → backup-folder → manager
# Place in ~/.shortcuts/ alongside the other scripts

SHORTCUTS="$HOME/.shortcuts"

# ── ANSI palette (matches segment_manager.py) ──────────────────────────
BOLD="\033[1m"
RESET="\033[0m"
GREEN="\033[32m"
YELLOW="\033[33m"
RED="\033[31m"
CYAN="\033[36m"
GRAY="\033[90m"
DIM="\033[2m"

# ── Helpers ─────────────────────────────────────────────────────────────

banner() {
    local step="$1" label="$2"
    echo ""
    echo -e "${BOLD}${CYAN}┌─────────────────────────────────────────┐${RESET}"
    printf "${BOLD}${CYAN}│  STEP %s / 3  %-27s│${RESET}\n" "$step" "$label"
    echo -e "${BOLD}${CYAN}└─────────────────────────────────────────┘${RESET}"
    echo ""
}

step_ok() {
    echo -e "\n${GREEN}${BOLD}✓ Step $1 complete${RESET}"
    echo -e "${DIM}────────────────────────────────────────────${RESET}"
    sleep 0.6
}

step_fail() {
    local step="$1" reason="$2"
    echo -e "\n${RED}${BOLD}✗ Step $step failed${RESET}  ${GRAY}(${reason})${RESET}"
    echo -e "${YELLOW}Pipeline halted — fix the issue and re-run.${RESET}\n"
    exit 1
}

confirm_continue() {
    echo -e "${GRAY}Press Enter to continue to step $1, or Ctrl+C to stop...${RESET}"
    read -r
}

# ── Header ───────────────────────────────────────────────────────────────

clear
echo -e "${BOLD}"
echo "  ╔══════════════════════════════════════════╗"
echo "  ║        CONTENT PIPELINE                  ║"
echo "  ║  org-album  →  backup-folder  →  manager ║"
echo "  ╚══════════════════════════════════════════╝"
echo -e "${RESET}"
echo -e "${GRAY}  $(date '+%A %b %-d, %Y  %-I:%M %p')${RESET}"
echo ""
echo -e "  ${DIM}This pipeline organises your shoot, zips a backup,${RESET}"
echo -e "  ${DIM}then opens the hashtag manager to prep for posting.${RESET}"
echo ""
sleep 0.4

# ═══════════════════════════════════════════════════════════════════════
# STEP 1 — Organise camera album
# Runs org-camera-album (interactive: termux-dialog for folder name,
# then moves files + media-scan)
# ═══════════════════════════════════════════════════════════════════════

banner 1 "Organise camera album"
echo -e "${GRAY}  → A dialog will ask for the destination folder name.${RESET}"
echo -e "${GRAY}  → Files will be moved from DCIM/Camera and gallery refreshed.${RESET}"
echo ""
confirm_continue 1

bash "$SHORTCUTS/org-camera-album"
EXIT_ORG=$?

if [ $EXIT_ORG -ne 0 ]; then
    # Exit code 0 also covers graceful "No folder entered" bail-out in org-camera-album.
    # That script uses exit 0 for the user-cancelled path, so we only land here on real errors.
    step_fail 1 "org-camera-album exited with code $EXIT_ORG"
fi

step_ok 1

# ═══════════════════════════════════════════════════════════════════════
# STEP 2 — Batch zip segment folders to Export/
# Default (y): batch-backup --hot zips all segments with counter >= 50.
#   pistol 341x, boulder 99x, mcp 87x, skip 56x + numbered variants.
# Custom (c): checkbox dialog to hand-pick which segments to zip.
# Single (n): falls back to backup-folder single-folder radio dialog.
# ═══════════════════════════════════════════════════════════════════════

banner 2 "Batch zip to Export/"
echo -e "${GRAY}  → Default: auto-zips all hot segments (counter >= 50).${RESET}"
echo -e "${GRAY}  → Numbered variants like mcp1, mcp2 are swept automatically.${RESET}"
echo ""
read -rp "$(echo -e "${GRAY}  Mode? (y=batch hot / c=custom select / n=single folder): ${RESET}")" BATCH_CHOICE

case "${BATCH_CHOICE,,}" in
    n)
        echo -e "${GRAY}  → Single-folder picker...${RESET}\n"
        bash "$SHORTCUTS/backup-folder"
        [ $? -ne 0 ] && step_fail 2 "backup-folder exited non-zero"
        ;;
    c)
        echo -e "${GRAY}  → Custom segment selector...${RESET}\n"
        bash "$SHORTCUTS/batch-backup"
        [ $? -ne 0 ] && step_fail 2 "batch-backup (custom) exited non-zero"
        ;;
    *)
        echo -e "${GRAY}  → Zipping hot segments...${RESET}\n"
        bash "$SHORTCUTS/batch-backup" --hot
        [ $? -ne 0 ] && step_fail 2 "batch-backup --hot exited non-zero"
        ;;
esac

step_ok 2

# ═══════════════════════════════════════════════════════════════════════
# STEP 3 — Hashtag manager
# Fully interactive Python REPL — stays open until user quits (q).
# Pipeline completes when manager exits cleanly.
# ═══════════════════════════════════════════════════════════════════════

banner 3 "Hashtag manager"
echo -e "${GRAY}  → Search for your content series, copy hashtags, update counter.${RESET}"
echo -e "${GRAY}  → Enter 'q' when done to finish the pipeline.${RESET}"
echo ""
confirm_continue 3

python "$SHORTCUTS/.hidden/segment_manager.py"
EXIT_MGR=$?

if [ $EXIT_MGR -ne 0 ]; then
    step_fail 3 "manager exited with code $EXIT_MGR"
fi

# ═══════════════════════════════════════════════════════════════════════
# Done
# ═══════════════════════════════════════════════════════════════════════

echo ""
echo -e "${BOLD}${GREEN}"
echo "  ╔══════════════════════════════════════════╗"
echo "  ║   ✓  PIPELINE COMPLETE                   ║"
echo "  ║                                          ║"
echo "  ║   Album organised  ✓                     ║"
echo "  ║   Folder backed up ✓                     ║"
echo "  ║   Hashtags copied  ✓                     ║"
echo "  ║                                          ║"
echo "  ║   Ready to post.                         ║"
echo "  ╚══════════════════════════════════════════╝"
echo -e "${RESET}"
echo ""
